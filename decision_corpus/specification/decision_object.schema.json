{
  "$schema": "https://json-schema.org/draft/2020-12/schema",

  "title": "Decision Object",

  "type": "object",

  "required": [
    "decision_id",
    "decision_type",
    "timestamp",
    "selected_action"
  ],

  "properties": {

    "decision_id": {
      "type": "string"
    },

    "decision_type": {
      "type": "string"
    },

    "timestamp": {
      "type": "string"
    },

    "context": {
      "type": "object"
    },

    "governance": {
      "type": "object"
    },

    "evidence": {
      "type": "array"
    },

    "alternatives": {
      "type": "array"
    },

    "selected_action": {
      "type": "string"
    },

    "expected_outcome": {
      "type": "object"
    },

    "actual_outcome": {
      "type": "object"
    },

    "relationships": {
      "type": "array"
    }
  }
}
